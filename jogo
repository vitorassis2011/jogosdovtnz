
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quebra Blocos - Jogo em HTML</title>
    <style>
        body {
            background-color: #2c3e50;
            color: #ecf0f1;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            text-align: center;
            margin: 0;
            padding: 0;
        }
        
        /* Tela de Login */
        #login-screen {
            margin-top: 15vh;
        }
        #login-screen h1 {
            font-size: 3em;
            color: #e74c3c;
            text-shadow: 2px 2px 0px #000;
        }
        #player-name {
            padding: 10px;
            font-size: 18px;
            border-radius: 5px;
            border: none;
            outline: none;
            text-align: center;
        }
        #btn-start {
            padding: 10px 20px;
            font-size: 18px;
            background-color: #27ae60;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            margin-top: 10px;
        }
        #btn-start:hover {
            background-color: #2ecc71;
        }

        /* Tela do Jogo */
        #game-screen {
            display: none;
            margin-top: 20px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            width: 480px;
            margin: 0 auto 10px auto;
            font-size: 20px;
            font-weight: bold;
            background: #34495e;
            padding: 10px;
            border-radius: 5px;
            box-sizing: border-box;
        }
        canvas {
            background: #111;
            border: 4px solid #bdc3c7;
            border-radius: 5px;
            box-shadow: 0px 0px 15px rgba(0,0,0,0.8);
        }
    </style>
</head>
<body>

    <div id="login-screen">
        <h1>BLOCO BLAST</h1>
        <p>Digite seu nome para começar:</p>
        <input type="text" id="player-name" placeholder="Seu Nome" autocomplete="off"><br>
        <button id="btn-start" onclick="iniciarJogo()">Jogar</button>
    </div>

    <div id="game-screen">
        <div class="header">
            <span id="display-name">Jogador: </span>
            <span id="display-level">Fase: 1</span>
            <span id="display-score">Pontos: 0</span>
        </div>
        <canvas id="gameCanvas" width="480" height="320"></canvas>
    </div>

    <script>
        // Variáveis de Controle de Tela
        const telaLogin = document.getElementById("login-screen");
        const telaJogo = document.getElementById("game-screen");
        const inputNome = document.getElementById("player-name");
        
        // Exibições no Placar
        const displayNome = document.getElementById("display-name");
        const displayFase = document.getElementById("display-level");
        const displayPontos = document.getElementById("display-score");

        // Configuração do Canvas (Onde o jogo é desenhado)
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");

        // Variáveis do Jogo
        let animationId;
        let nomeJogador = "";
        let pontos = 0;
        let fase = 1;

        // Configurações da Bolinha
        let raioBola = 8;
        let x = canvas.width / 2;
        let y = canvas.height - 30;
        let dx = 3; // Velocidade horizontal
        let dy = -3; // Velocidade vertical

        // Configurações da Base (Paddle)
        let alturaBase = 10;
        let larguraBase = 75;
        let xBase = (canvas.width - larguraBase) / 2;
        let setaDireita = false;
        let setaEsquerda = false;

        // Configurações dos Blocos
        let linhasBlocos = 3;
        let colunasBlocos = 5;
        let larguraBloco = 75;
        let alturaBloco = 20;
        let espacamentoBloco = 10;
        let margemTopo = 30;
        let margemEsquerda = 30;
        let blocos = [];

        // Capturar teclas do teclado
        document.addEventListener("keydown", apertarTecla, false);
        document.addEventListener("keyup", soltarTecla, false);

        function apertarTecla(e) {
            if(e.key == "Right" || e.key == "ArrowRight") setaDireita = true;
            else if(e.key == "Left" || e.key == "ArrowLeft") setaEsquerda = true;
        }

        function soltarTecla(e) {
            if(e.key == "Right" || e.key == "ArrowRight") setaDireita = false;
            else if(e.key == "Left" || e.key == "ArrowLeft") setaEsquerda = false;
        }

        // Função de Login
        function iniciarJogo() {
            if (inputNome.value.trim() === "") {
                alert("Por favor, digite seu nome!");
                return;
            }
            nomeJogador = inputNome.value;
            displayNome.innerText = "Jogador: " + nomeJogador;
            
            telaLogin.style.display = "none";
            telaJogo.style.display = "block";
            
            criarBlocos();
            desenhar();
        }

        // Cria os blocos baseados na fase atual
        function criarBlocos() {
            linhasBlocos = 2 + fase; // A cada fase, adiciona mais uma linha de blocos
            blocos = [];
            for(let c = 0; c < colunasBlocos; c++) {
                blocos[c] = [];
                for(let l = 0; l < linhasBlocos; l++) {
                    blocos[c][l] = { x: 0, y: 0, status: 1 };
                }
            }
            
            // Aumenta a velocidade da bola a cada fase
            let velocidadeBase = 2 + (fase * 0.5);
            dx = velocidadeBase;
            dy = -velocidadeBase;
            
            // Centraliza a bolinha e a base
            x = canvas.width / 2;
            y = canvas.height - 30;
            xBase = (canvas.width - larguraBase) / 2;
        }

        // Detecta quando a bola bate em um bloco
        function detectarColisao() {
            for(let c = 0; c < colunasBlocos; c++) {
                for(let l = 0; l < linhasBlocos; l++) {
                    let b = blocos[c][l];
                    if(b.status == 1) {
                        // Se a bola estiver dentro das coordenadas do bloco
                        if(x > b.x && x < b.x + larguraBloco && y > b.y && y < b.y + alturaBloco) {
                            dy = -dy; // Inverte a direção vertical
                            b.status = 0; // "Quebra" o bloco
                            pontos += 10;
                            displayPontos.innerText = "Pontos: " + pontos;
                            
                            verificarVitoria();
                        }
                    }
                }
            }
        }

        // Verifica se todos os blocos foram quebrados
        function verificarVitoria() {
            let blocosRestantes = 0;
            for(let c = 0; c < colunasBlocos; c++) {
                for(let l = 0; l < linhasBlocos; l++) {
                    if(blocos[c][l].status == 1) blocosRestantes++;
                }
            }
            
            if(blocosRestantes === 0) {
                cancelAnimationFrame(animationId);
                alert("Parabéns " + nomeJogador + "! Você passou para a Fase " + (fase + 1) + "!");
                fase++;
                displayFase.innerText = "Fase: " + fase;
                criarBlocos();
                desenhar(); // Reinicia o loop
            }
        }

        // Funções de Desenho (Bola, Base e Blocos)
        function desenharBola() {
            ctx.beginPath();
            ctx.arc(x, y, raioBola, 0, Math.PI*2);
            ctx.fillStyle = "#e74c3c";
            ctx.fill();
            ctx.closePath();
        }

        function desenharBase() {
            ctx.beginPath();
            ctx.rect(xBase, canvas.height - alturaBase, larguraBase, alturaBase);
            ctx.fillStyle = "#3498db";
            ctx.fill();
            ctx.closePath();
        }

        function desenharBlocos() {
            for(let c = 0; c < colunasBlocos; c++) {
                for(let l = 0; l < linhasBlocos; l++) {
                    if(blocos[c][l].status == 1) {
                        let blocoX = (c * (larguraBloco + espacamentoBloco)) + margemEsquerda;
                        let blocoY = (l * (alturaBloco + espacamentoBloco)) + margemTopo;
                        blocos[c][l].x = blocoX;
                        blocos[c][l].y = blocoY;
                        
                        ctx.beginPath();
                        ctx.rect(blocoX, blocoY, larguraBloco, alturaBloco);
                        // Cores diferentes por linha
                        let cores = ["#f1c40f", "#e67e22", "#9b59b6", "#1abc9c", "#e74c3c"];
                        ctx.fillStyle = cores[l % cores.length];
                        ctx.fill();
                        ctx.closePath();
                    }
                }
            }
        }

        // Loop principal do Jogo
        function desenhar() {
            // Limpa o frame anterior
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            desenharBlocos();
            desenharBola();
            desenharBase();
            detectarColisao();

            // Colisão com as paredes esquerda e direita
            if(x + dx > canvas.width - raioBola || x + dx < raioBola) {
                dx = -dx;
            }
            
            // Colisão com o teto
            if(y + dy < raioBola) {
                dy = -dy;
            } 
            // Colisão com o chão / Base
            else if(y + dy > canvas.height - raioBola) {
                // Se bater na base
                if(x > xBase && x < xBase + larguraBase) {
                    dy = -dy;
                } else {
                    // Game Over
                    alert("GAME OVER! Fim de jogo, " + nomeJogador + ". Sua pontuação foi: " + pontos);
                    document.location.reload(); // Recarrega a página
                    return;
                }
            }

            // Movimentação da Base
            if(setaDireita && xBase < canvas.width - larguraBase) {
                xBase += 7;
            } else if(setaEsquerda && xBase > 0) {
                xBase -= 7;
            }

            // Move a bola
            x += dx;
            y += dy;

            // Chama o próximo frame
            animationId = requestAnimationFrame(desenhar);
        }
    </script>
</body>
</html>
